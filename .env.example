# Local object storage (see docker-compose.yml). Copy to .env if your tooling loads it.
#
# If you omit s3.accessKey and s3.secretKey in config.yaml, the AWS SDK default
# chain is used — set these in the environment instead:
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# AWS_REGION=us-east-1
